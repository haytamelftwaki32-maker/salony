{
  "name": "salony-workspace",
  "private": true,
  "scripts": {
    "build": "npm install && cd client && npm install && npm run build && cd .. && npx prisma generate && npx prisma db push --accept-data-loss && rm -rf public && mkdir public && cp -r client/dist/* public/",
    "dev:client": "cd client && npm run dev",
    "dev:server": "nodemon api/index.ts",
    "start": "node api/index.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.6",
    "@types/socket.io": "^3.0.1",
    "nodemon": "^3.1.11",
    "prisma": "5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
